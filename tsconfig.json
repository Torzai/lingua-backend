{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2021",
    "lib": [
      "ES2021"
    ],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@auth/*": [
        "./src/auth/*"
      ],
      "@users/*": [
        "./src/users/*"
      ],
      "@vocabulary/*": [
        "./src/vocabulary/*"
      ],
      "@progress/*": [
        "./src/progress/*"
      ],
      "@exercises/*": [
        "./src/exercises/*"
      ],
      "@points/*": [
        "./src/points/*"
      ],
      "@chat/*": [
        "./src/chat/*"
      ],
      "@common/*": [
        "./src/common/*"
      ],
      "@config/*": [
        "./src/config/*"
      ]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "test",
    "**/*.spec.ts"
  ]
}